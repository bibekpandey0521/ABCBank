<Header OnClose="PageClosed" Title="BankAccounts" Description="Account Holder's Bank Accounts."/>
@if (_loading)
{
    <MudProgressCircular Size="Size.Large" Color="Color.Info" Indeterminate=true />
}
else
{
    <MudCard Elevation="25">
        <MudCardContent>
            <MudTable Items="Accounts" Elevation="25" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" LoadingProgressColor="Color.Info">
                <ToolBarContent>
                    <MudFab Color="Color.Primary"
                            StartIcon="@Icons.Material.Filled.Add"
                            Size="Size.Small"
                            OnClick="(()=> AddAccountAsync())"/>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>AccountNumber</MudTh>
                    <MudTh>Balance</MudTh>
                    <MudTh>IsActive</MudTh>
                    <MudTh>Account Type</MudTh>
                    <MudTh Style="text-align:right">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="AccountNumber">@context.AccountNumber</MudTd>
                    <MudTd DataLabel="Balance">
                        @context.Balance.ToString("C",new System.Globalization.CultureInfo("ne-NP"))</MudTd>
                    <MudTd DataLabel="Account Type">
                        <MudCheckBox  @bind-Value="@context.IsActive"  ReadOnly="true" Color="Color.Primary"></MudCheckBox>    
                    </MudTd>
                    <MudTd DataLabel="ContactNo">@context.Type.ToString()</MudTd>
                    <MudTd DataLabel="Actions" Style="text-align:right">
                        <MudMenu Label="Manage" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" IconColor="Color.Secondary">
                            <MudMenuItem OnClick="(() => TransactAsync(context.Id, context.Balance))">Transact</MudMenuItem>
                            <MudMenuItem OnClick="(() => History(context.Id))">History</MudMenuItem>
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudCardContent>
    </MudCard>
}