<MudForm @ref="@_form" Model="CreateAccountHolderRequest" Validation="@(_validator.ValidateValue)" ValidationDelay="0">
    <MudDialog>
        <TitleContent>
            Add Account Holder
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12"  sm="6" md="6">
                    <MudTextField @bind-Value="CreateAccountHolderRequest.FirstName"
                                  Label="FirstName"
                                  Margin="Margin.Dense"
                                  For="@(() => CreateAccountHolderRequest.FirstName)"
                                  Variant="Variant.Outlined"></MudTextField>

                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudTextField @bind-Value="CreateAccountHolderRequest.LastName"
                                  Label="LastName"
                                  Margin="Margin.Dense"
                                  For="@(() => CreateAccountHolderRequest.LastName)"
                                  Variant="Variant.Outlined">LastName</MudTextField>
                        
                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudDatePicker @bind-Date="CreateAccountHolderRequest.DateOfBirth"
                                   Label="Date Of Birth"
                                   Editable="true"
                                   Margin="Margin.Dense"
                                   For="@(()=> CreateAccountHolderRequest.DateOfBirth)"
                                   Placeholder="Select Dob"></MudDatePicker>
                        
                        
                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudTextField @bind-Value="CreateAccountHolderRequest.ContactNumber"
                                  Label="Contact No"
                                  Margin="Margin.Dense"
                                  For="@(() => CreateAccountHolderRequest.ContactNumber)"
                                  Variant="Variant.Outlined">
                        Contact Number
                    </MudTextField>
                        
                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudTextField @bind-Value="CreateAccountHolderRequest.Email"
                                  Label="Email"
                                  Margin="Margin.Dense"
                                  For="@(() => CreateAccountHolderRequest.Email)"
                                  Variant="Variant.Outlined">
                        Email
                    </MudTextField>
                </MudItem>
            </MudGrid>

        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancel" Class="mr-auto">Cancel</MudButton>
            <MudButton Color="Color.Success" Class="me-4" OnClick="SubmitAsync"
                       Variant="Variant.Filled"
                       Disabled="@(!_validator.Validate(CreateAccountHolderRequest).IsValid)">Save</MudButton>
        </DialogActions>
    </MudDialog>
</MudForm>
