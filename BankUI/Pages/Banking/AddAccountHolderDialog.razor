<MudForm @ref="@_form" Model="CreateAccountHolderRequest">
    <MudDialog>
        <TitleContent>
            Add Account Holder
        </TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="CreateAccountHolderRequest.FirstName"
            Label="Outlined" Variant="Variant.Outlined"></MudTextField>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancel">Cancel</MudButton>
            <MudButton Color="Color.Primary" OnClick="SaveAsync">OK</MudButton>
        </DialogActions>
    </MudDialog>
</MudForm>