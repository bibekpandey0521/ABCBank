@using Common.Enums;
<MudForm @ref="@_form" Model="TransactionRequest">
    <MudDialog>
        <TitleContent>
            Account Transaction
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12" sm="12" md="12">
                    <MudNumericField @bind-Value="Balance"
                                     Label="Curent Balance"
                                     Margin="Margin.Dense"
                                     Adornment="Adornment.Start"
                                     AdornmentText="R"
                                     AdormentColor="Color.Info"
                                     ReadOnly="true"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudNumericField @bind-Value="TransactionRequest.Amount"
                                     Label="Transaction Amount"
                                     Margin="Margin.Dense"
                                     Adornment="Adornment.Start"
                                     AdornmentText="R"
                                     AdormentColor="Color.Info"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudSelect @bind-Value="TransactionRequest.Type"
                               Label="Transaction Type"
                               Margin="Margin.Dense"
                               Variant="Variant.Outlined">
                        @foreach (TransactionType type in Enum.GetValues(typeof(TransactionType)))
                        {
                            <MudSelectItem Value="@(type)">@type</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancel" Class="mr-auto">Cancel</MudButton>
            <MudButton Color="Color.Success" Class="me-4" OnClick="SubmitAsync"
                       Variant="Variant.Filled">Save</MudButton>
        </DialogActions>
    </MudDialog>
</MudForm>