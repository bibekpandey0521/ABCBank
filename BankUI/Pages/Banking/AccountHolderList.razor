@page "/banking/account-holder-list"

<MudCard Elevation="25">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudAvatar>
                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" />
            </MudAvatar>
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudText Type="Typo.body1">Account Holders</MudText>
            <MudText Type="Typo.body2">All Account Holders</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudTable Items="@AccountHolders" Elevation="25" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Si Loading="@_loading" Size="Size.Small" LoadingProgressColor="Color.Info">
            <ToolBarContent>
                <MudFab Color="Color.Primary"
                        StartIcon="@Icons.Material.Filled.Add"
                        Size="Size.Small"
                        OnClick="(() =>  AddAccountHolderAsync())" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>FirstName</MudTh>
                <MudTh>LastName</MudTh>
                <MudTh>DOB</MudTh>
                <MudTh>ContactNo</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="FirstName">@context.FirstName</MudTd>
                <MudTd DataLabel="LastName">@context.LastName</MudTd>
                <MudTd DataLabel="DOB">@context.DateOfBirth.ToString("dd MMMM yyyy")</MudTd>
                <MudTd DataLabel="ContactNo">@context.ContactNumber</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Actions">
                    <MudMenu Label="Manage" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" IconColor="Color.Secondary">
                        <MudMenuItem OnClick="(() => UpdateAccountHolderAsync(context.Id))">Update</MudMenuItem>
                        <MudMenuItem OnClick="(()=> ManageAccounts(context.Id))">Accounts</MudMenuItem>
                        <MudMenuItem OnClick="(() => DeleteAsync(context.Id, context.FirstName, context.LastName))">Delete</MudMenuItem>
                    </MudMenu>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudCardContent>
</MudCard>

