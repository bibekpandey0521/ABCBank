@page "/banking/manage-accounts/{AccountHolderId:int}"

<Header onclose="PageClosed" Title="Manage Accounts" Description="Manage Account Holde's Accouts." />

@if (_loading)
{
    <MudProgressCircular Size="Size.Large" Color="Color.Info" Indeterminate=true />
}
else
{
    <MudExpansionPanel Disabled="false"
                       Style="padding:10px!important; margin-bottom:10px!important;border-radius: var(--mud-default-borderradius) !important;"
                       Class="mud-elevation-25" Text="Account Holder">
        <MudGrid Class="py-2">
            <MudItem xs="12" sm="6" md="6">
                <MudTextField Label="FirstName" @bind-Value="AccountHolder.FirstName" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="6">
                <MudTextField Label="LastName" @bind-Value="AccountHolder.LastName" ReadOnly="true" />
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>


    <MudTabs Elevation="25" Rounded="true" Outlined="false" Color="@Color.Transparent" PanelClass="mt-6">
        <MudTabPanel Text="Bank Accounts">
          <AccountList AccountHolderId="AccountHolderId"/>
        </MudTabPanel>
    </MudTabs>
}